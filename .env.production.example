SECRET_KEY=change-me
DEBUG=False
DB_ENGINE=mysql
DB_NAME=medicore_db
DB_USER=medicore_user
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,SERVER_PUBLIC_IP
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
DOCUMENT_MAX_UPLOAD_SIZE_MB=10
DOCUMENT_ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,webp,doc,docx,xls,xlsx
DOCUMENT_STORAGE_BACKEND=local
DEFAULT_FROM_EMAIL=no-reply@your-domain.com
FRONTEND_URL=https://your-domain.com
PASSWORD_RESET_TOKEN_MINUTES=30
EMAIL_VERIFICATION_TOKEN_MINUTES=60
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15
SESSION_LIFETIME_MINUTES=1440
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
